# Copy this file to .env and fill in your values.
# IMPORTANT: .env is gitignored — never commit real credentials.
#
# JIRA_DOMAIN  → the part before .atlassian.net in your Jira URL
#                e.g. if your Jira is at  acme.atlassian.net  →  JIRA_DOMAIN=acme
#
# JIRA_EMAIL   → the email you use to log into Jira
#
# JIRA_API_TOKEN → create one at:
#                  https://id.atlassian.com/manage-profile/security/api-tokens

JIRA_DOMAIN=your-domain
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=paste-your-token-here

# JIRA_BASE_URL=https://your-domain.atlassian.net
# JIRA_USER_EMAIL=your-email@company.com
# JIRA_API_TOKEN=          # Generate at https://id.atlassian.com/manage/api-tokens
# CONFLUENCE_BASE_URL=https://your-domain.atlassian.net/wiki
# CONFLUENCE_SPACE_KEY=    # e.g., "ENG"