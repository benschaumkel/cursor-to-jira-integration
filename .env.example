# ─────────────────────────────────────────────────────────
# SECRETS ONLY — structural config lives in config.yaml
# Copy to .env:  cp .env.example .env
# ─────────────────────────────────────────────────────────

# ── Primary Atlassian Instance ───────────────────────────
JIRA_EMAIL=
JIRA_API_TOKEN=            # https://id.atlassian.com/manage-profile/security/api-tokens

# ── Additional Instances (optional) ──────────────────────
# Add credentials for each profile defined in config.yaml.
# The env var names must match auth.email_env / auth.token_env
# in your profile definition.
#
# SECONDARY_JIRA_EMAIL=
# SECONDARY_JIRA_API_TOKEN=
